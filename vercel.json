{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/router.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "api/**"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/router?route=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
