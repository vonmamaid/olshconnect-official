{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/router.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "api/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/router", "dest": "/api/router" },
    { "src": "/api/(?!router$)(.*)", "dest": "/api/router?route=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
